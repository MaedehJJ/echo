{
  "manifest_version": 3,
  "name": "Echo",
  "version": "0.1.0",
  "description": "A lightweight AI assistant side panel backed by local Ollama.",
  "permissions": ["sidePanel", "scripting"],
  "host_permissions": ["http://localhost:11434/*", "<all_urls>"],
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_title": "Open Echo",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  }
}
